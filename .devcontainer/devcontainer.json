{
  "name": "Aula FHIR - SDIB",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12",
      "installTools": false
    }
  },
  "postCreateCommand": "cd js && cp -n .env.example .env && npm install && pip install -r ../requirements.txt",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "FHIR Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "humao.rest-client"
      ]
    }
  }
}
