<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= patient.name %> - <%= title %></title>
  <link rel="stylesheet" href="/style.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <main class="container patient-page">
    <section class="panel hero-panel">
      <div class="panel-header">
        <div>
          <h1><%= patient.name %></h1>
          <p class="muted">Dados do doente: <strong><%= patient.name %></strong></p>
        </div>
        <div class="header-actions">
          <a id="back-to-patients" class="btn" href="/">Voltar à lista de doentes</a>
          <span class="chip">ID FHIR: <%= patient.id %></span>
        </div>
      </div>

      <% if (insertedMessage) { %>
        <div class="notice success"><%= insertedMessage %></div>
      <% } %>

      <div class="info-grid compact">
        <article class="info-tile full-span">
          <span class="info-label">Nome do doente</span>
          <strong><%= patient.name %></strong>
        </article>
        <article class="info-tile">
          <span class="info-label">Data de nascimento</span>
          <strong><%= patient.birthDate %></strong>
        </article>
        <article class="info-tile">
          <span class="info-label">Sexo</span>
          <strong><%= patient.gender %></strong>
        </article>
        <article class="info-tile full-span">
          <span class="info-label">Diagnóstico renal principal</span>
          <strong><%= patient.diagnosisText %> <small>(ICD-10: <%= patient.diagnosisCode %>)</small></strong>
        </article>
      </div>
    </section>

    <section class="cards-grid four">
      <% cards.forEach(function(card){ %>
        <article class="metric-card">
          <h2><%= card.label %></h2>
          <div class="metric-value"><%= card.value %></div>
          <p><strong>Data:</strong> <%= card.date %></p>
          <p><strong>LOINC:</strong> <%= card.loinc %></p>
          <p><strong>Notas:</strong> <%= card.note %></p>
        </article>
      <% }) %>
    </section>

    <section class="panel">
      <div class="panel-header simple">
        <h2>Inserir observação</h2>
      </div>
      <div class="forms-grid">
        <form method="post" action="/patients/<%= patient.id %>/observations" class="obs-form">
          <input type="hidden" name="type" value="bp" />
          <h3>Pressão arterial</h3>
          <div class="form-row two">
            <label>Sistólica
              <input type="number" step="1" name="systolic" required />
            </label>
            <label>Diastólica
              <input type="number" step="1" name="diastolic" required />
            </label>
          </div>
          <label>Data/Hora
            <input type="datetime-local" name="effectiveDateTime" />
          </label>
          <button class="btn" type="submit">Inserir</button>
        </form>

        <form method="post" action="/patients/<%= patient.id %>/observations" class="obs-form">
          <input type="hidden" name="type" value="lab" />
          <h3>Valor laboratorial</h3>
          <div class="form-row two">
            <label>Métrica
              <select name="metricKey" required>
                <option value="egfr">TFG / eGFR</option>
                <option value="creatinine">Creatinina</option>
                <option value="urea">Ureia / BUN</option>
              </select>
            </label>
            <label>Valor
              <input type="number" step="0.1" name="value" required />
            </label>
          </div>
          <label>Data/Hora
            <input type="datetime-local" name="effectiveDateTime" />
          </label>
          <button class="btn" type="submit">Inserir</button>
        </form>
      </div>
    </section>

    <section class="panel">
      <div class="panel-header simple">
        <h2>Histórico de dados</h2>
      </div>
      <table class="history-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Exame</th>
            <th>Valor</th>
            <th>LOINC</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (!historyRows.length) { %>
            <tr><td colspan="5">Sem dados para mostrar.</td></tr>
          <% } %>
          <% historyRows.forEach(function(row){ %>
            <tr>
              <td><%= row.date %></td>
              <td><%= row.metricLabel %></td>
              <td><%= row.value %></td>
              <td><%= row.loinc %></td>
              <td><%= row.status %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>

    <section class="charts-grid">
      <article class="panel chart-panel"><h3>Pressão arterial</h3><canvas id="chart-bp"></canvas></article>
      <article class="panel chart-panel"><h3>TFG / eGFR</h3><canvas id="chart-egfr"></canvas></article>
      <article class="panel chart-panel"><h3>Creatinina</h3><canvas id="chart-creatinine"></canvas></article>
      <article class="panel chart-panel"><h3>Ureia / BUN</h3><canvas id="chart-urea"></canvas></article>
    </section>
  </main>

  <script>
    const charts = <%- JSON.stringify(charts) %>;

    function createLineChart(canvasId, label, labels, values) {
      new Chart(document.getElementById(canvasId), {
        type: 'line',
        data: {
          labels,
          datasets: [{ label, data: values, tension: 0.25 }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: { y: { beginAtZero: false } }
        }
      });
    }

    function createBpChart() {
      const data = charts.bp || { labels: [], systolic: [], diastolic: [] };
      new Chart(document.getElementById('chart-bp'), {
        type: 'line',
        data: {
          labels: data.labels,
          datasets: [
            { label: 'Sistólica', data: data.systolic, tension: 0.25 },
            { label: 'Diastólica', data: data.diastolic, tension: 0.25 }
          ]
        },
        options: { responsive: true, maintainAspectRatio: false }
      });
    }

    const currentUrl = new URL(window.location.href);
    const returnTo = currentUrl.searchParams.get('returnTo');
    const backButton = document.getElementById('back-to-patients');

    if (returnTo) {
      backButton.href = returnTo;
    } else {
      backButton.href = '/';
    }

    async function submitObservationForm(form) {
      const submitButton = form.querySelector('button[type="submit"]');
      const originalLabel = submitButton ? submitButton.textContent : '';

      try {
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = 'A guardar...';
        }

        const response = await fetch(form.action, {
          method: form.method || 'POST',
          body: new FormData(form),
          credentials: 'same-origin',
          cache: 'no-store'
        });

        if (!response.ok) {
          throw new Error('Falha ao guardar a observação.');
        }

        const reloadUrl = new URL(window.location.href);
        reloadUrl.searchParams.set('_ts', Date.now().toString());
        window.location.replace(reloadUrl.toString());
      } catch (error) {
        console.error(error);
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = originalLabel;
        }
        form.submit();
      }
    }

    document.querySelectorAll('.obs-form').forEach((form) => {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        submitObservationForm(form);
      });
    });

    createBpChart();
    createLineChart('chart-egfr', 'TFG / eGFR', charts.egfr.labels || [], charts.egfr.values || []);
    createLineChart('chart-creatinine', 'Creatinina', charts.creatinine.labels || [], charts.creatinine.values || []);
    createLineChart('chart-urea', 'Ureia / BUN', charts.urea.labels || [], charts.urea.values || []);
  </script>
</body>
</html>
